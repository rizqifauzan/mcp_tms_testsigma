{
  "name": "mcp-tms-testsigma",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server bridging Claude to Testsigma TMS REST API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "vercel dev",
    "deploy": "vercel deploy --prod",
    "smoke": "tsx scripts/smoke.mjs",
    "e2e": "tsx --env-file=.env scripts/e2e.mjs",
    "e2e:phase2": "tsx --env-file=.env scripts/e2e_phase2.mjs",
    "e2e:phase4": "tsx --env-file=.env scripts/e2e_phase4.mjs",
    "test:url-auth": "tsx --env-file=.env scripts/test_url_auth.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vercel": "^39.0.0"
  }
}
